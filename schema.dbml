// =============================================================
//  devlivery — Database Schema
//  Format: DBML (Database Markup Language)
//  Auth: Better Auth (core + organization plugin)
//  DB Target: PostgreSQL
//  Version: 1.0.0
// =============================================================

// =============================================================
// SECTION 1: BETTER AUTH — CORE TABLES
// Tabel-tabel ini di-generate otomatis oleh better-auth CLI.
// Jangan dimodifikasi manual. Field tambahan ditambahkan
// via `additionalFields` di konfigurasi better-auth.
// =============================================================

Table user {
  id                  varchar     [pk, note: 'UUID, generated by better-auth']
  name                varchar     [not null]
  email               varchar     [not null, unique]
  email_verified      boolean     [not null, default: false]
  image               varchar
  created_at          timestamp   [not null, default: `now()`]
  updated_at          timestamp   [not null, default: `now()`]

  // Tambahan field (additionalFields di config better-auth)
  is_superadmin       boolean     [not null, default: false, note: 'Hanya untuk admin platform devlivery sendiri']

  Note: 'Core table dari better-auth. Menyimpan identitas pengguna.'
}

Table session {
  id                  varchar     [pk]
  expires_at          timestamp   [not null]
  token               varchar     [not null, unique]
  created_at          timestamp   [not null, default: `now()`]
  updated_at          timestamp   [not null, default: `now()`]
  ip_address          varchar
  user_agent          varchar
  user_id             varchar     [not null, ref: > user.id]

  // Tambahan field
  active_organization_id varchar   [ref: > organization.id, note: 'Organisasi yang sedang aktif di sesi ini']

  Note: 'Core table dari better-auth. Menyimpan sesi login aktif.'
}

Table account {
  id                        varchar   [pk]
  account_id                varchar   [not null]
  provider_id               varchar   [not null, note: 'e.g.: google, credential']
  user_id                   varchar   [not null, ref: > user.id]
  access_token              text
  refresh_token             text
  id_token                  text
  access_token_expires_at   timestamp
  refresh_token_expires_at  timestamp
  scope                     varchar
  password                  varchar   [note: 'Hashed. Diisi hanya untuk credential provider.']
  created_at                timestamp [not null, default: `now()`]
  updated_at                timestamp [not null, default: `now()`]

  Note: 'Core table dari better-auth. Menyimpan akun OAuth & credential.'
}

Table verification {
  id            varchar   [pk]
  identifier    varchar   [not null, note: 'Biasanya email address']
  value         varchar   [not null, note: 'Token verifikasi']
  expires_at    timestamp [not null]
  created_at    timestamp [default: `now()`]
  updated_at    timestamp [default: `now()`]

  Note: 'Core table dari better-auth. Untuk email verification & password reset.'
}


// =============================================================
// SECTION 2: BETTER AUTH — ORGANIZATION PLUGIN TABLES
// Di-generate oleh better-auth organization plugin.
// =============================================================

Table organization {
  id          varchar   [pk]
  name        varchar   [not null]
  slug        varchar   [not null, unique, note: 'URL-friendly identifier, e.g.: gdgoc-ui']
  logo        varchar   [note: 'URL logo organisasi']
  metadata    jsonb
  created_at  timestamp [not null, default: `now()`]

  // Tambahan field (additionalFields)
  plan              varchar     [not null, default: 'free', note: 'free | pro | enterprise']
  email_quota_limit int         [not null, default: 500, note: 'Max email/bulan']
  email_quota_used  int         [not null, default: 0]
  quota_reset_at    timestamp   [note: 'Kapan kuota di-reset (awal bulan)']
  is_active         boolean     [not null, default: true]
  sender_email      varchar     [note: 'Email pengirim yang dihubungkan via OAuth/SMTP']
  sender_name       varchar     [note: 'Display name pengirim email']

  Note: 'Tenant utama. Satu organisasi = satu workspace terisolasi.'
}

Table member {
  id              varchar   [pk]
  organization_id varchar   [not null, ref: > organization.id]
  user_id         varchar   [not null, ref: > user.id]
  role            varchar   [not null, note: 'owner | admin | manager | viewer']
  created_at      timestamp [not null, default: `now()`]

  indexes {
    (organization_id, user_id) [unique, name: 'uq_org_member']
  }

  Note: 'Join table antara user dan organization. Role menentukan akses RBAC.'
}

Table invitation {
  id              varchar   [pk]
  organization_id varchar   [not null, ref: > organization.id]
  email           varchar   [not null, note: 'Email yang diundang']
  role            varchar   [not null, note: 'Role yang akan diberikan: admin | manager | viewer']
  status          varchar   [not null, default: 'pending', note: 'pending | accepted | rejected | expired']
  expires_at      timestamp [not null]
  inviter_id      varchar   [not null, ref: > user.id]
  created_at      timestamp [not null, default: `now()`]

  Note: 'Undangan bergabung ke organisasi. Dikirim via email.'
}

// Kredensial SMTP/OAuth per organisasi untuk mengirim email
// (terpisah dari better-auth OAuth yang untuk login)
Table organization_email_credential {
  id                        varchar   [pk, default: `gen_random_uuid()`]
  organization_id           varchar   [not null, unique, ref: > organization.id]
  provider                  varchar   [not null, note: 'gmail_oauth | smtp']

  // Untuk Gmail OAuth
  google_access_token       text      [note: 'Encrypted. Token akses Gmail API.']
  google_refresh_token      text      [note: 'Encrypted. Refresh token Gmail API.']
  google_token_expires_at   timestamp

  // Untuk SMTP kustom
  smtp_host                 varchar
  smtp_port                 int
  smtp_username             varchar
  smtp_password             text      [note: 'Encrypted']
  smtp_secure               boolean   [default: true]

  created_at  timestamp [not null, default: `now()`]
  updated_at  timestamp [not null, default: `now()`]

  Note: 'Menyimpan kredensial email pengirim per organisasi. Semua token dienkripsi (Fernet/AES).'
}


// =============================================================
// SECTION 3: CAMPAIGN
// =============================================================

Table campaign {
  id              varchar   [pk, default: `gen_random_uuid()`]
  organization_id varchar   [not null, ref: > organization.id]
  created_by      varchar   [not null, ref: > user.id]

  name            varchar   [not null]
  slug            varchar   [not null, note: 'URL-friendly, unik dalam satu organisasi']
  description     text
  cover_image_url varchar
  event_date      timestamp
  location        varchar   [note: 'Nama tempat / "Online"']
  status          varchar   [not null, default: 'draft', note: 'draft | published | ongoing | completed | archived']

  // QR Code
  qr_code_token   varchar   [unique, note: 'Token unik untuk validasi scan QR. Di-generate saat campaign dibuat.']
  qr_code_url     varchar   [note: 'URL yang di-encode ke dalam QR Code: /scan/{qr_code_token}']

  // Pengaturan absensi
  attendance_open_at  timestamp [note: 'Kapan absensi QR mulai bisa digunakan']
  attendance_close_at timestamp [note: 'Kapan absensi QR ditutup']

  created_at  timestamp [not null, default: `now()`]
  updated_at  timestamp [not null, default: `now()`]

  indexes {
    (organization_id, slug) [unique, name: 'uq_campaign_org_slug']
    organization_id         [name: 'idx_campaign_org']
  }

  Note: 'Satu campaign = satu event. Semua data diikat ke campaign ini.'
}


// =============================================================
// SECTION 4: FORM PENDAFTARAN DINAMIS
// =============================================================

Table form_field {
  id          varchar   [pk, default: `gen_random_uuid()`]
  campaign_id varchar   [not null, ref: > campaign.id]

  label       varchar   [not null, note: 'Teks pertanyaan yang ditampilkan ke peserta']
  field_key   varchar   [not null, note: 'Key unik dalam satu campaign, e.g.: nama, email, instansi']
  field_type  varchar   [not null, note: 'text | textarea | email | phone | number | radio | checkbox | dropdown | file | date']
  placeholder varchar
  is_required boolean   [not null, default: false]
  sort_order  int       [not null, default: 0, note: 'Urutan tampil di form']
  options     jsonb     [note: 'Array string untuk tipe radio/checkbox/dropdown. e.g.: ["Peserta","Panitia"]']
  validation  jsonb     [note: 'Aturan validasi tambahan, e.g.: {min: 10, max: 100}']
  is_active   boolean   [not null, default: true]

  created_at  timestamp [not null, default: `now()`]
  updated_at  timestamp [not null, default: `now()`]

  indexes {
    campaign_id [name: 'idx_form_field_campaign']
    (campaign_id, field_key) [unique, name: 'uq_field_key_per_campaign']
  }

  Note: 'Definisi satu kolom/pertanyaan di form pendaftaran. Dibuat oleh panitia via Form Builder.'
}

Table form_submission {
  id          varchar   [pk, default: `gen_random_uuid()`]
  campaign_id varchar   [not null, ref: > campaign.id]

  // Identitas peserta (di-cache dari form_submission_value untuk performa)
  respondent_name   varchar [note: 'Di-extract dari field dengan field_key = "nama" atau yang ditandai sebagai identifier']
  respondent_email  varchar [not null, note: 'Wajib ada, untuk pengiriman sertifikat']

  is_registered boolean   [not null, default: true, note: 'Selalu true, untuk membedakan dari scan non-peserta']
  submitted_at  timestamp [not null, default: `now()`]

  indexes {
    campaign_id                   [name: 'idx_submission_campaign']
    (campaign_id, respondent_email) [unique, name: 'uq_email_per_campaign', note: 'Mencegah pendaftaran ganda']
  }

  Note: 'Satu record = satu pengisian form oleh satu peserta.'
}

Table form_submission_value {
  id            varchar   [pk, default: `gen_random_uuid()`]
  submission_id varchar   [not null, ref: > form_submission.id]
  field_id      varchar   [not null, ref: > form_field.id]
  field_key     varchar   [not null, note: 'Di-denormalisasi dari form_field untuk performa query']
  value         text      [note: 'Nilai jawaban. Array JSON (stringify) untuk checkbox.']
  file_url      varchar   [note: 'URL file jika field_type = file']

  indexes {
    submission_id [name: 'idx_value_submission']
    (submission_id, field_id) [unique, name: 'uq_value_per_field']
  }

  Note: 'Jawaban individual per field dari satu submission. EAV pattern.'
}


// =============================================================
// SECTION 5: ABSENSI QR CODE
// =============================================================

Table attendance_record {
  id            varchar   [pk, default: `gen_random_uuid()`]
  campaign_id   varchar   [not null, ref: > campaign.id]
  submission_id varchar   [not null, ref: > form_submission.id]

  scanned_at    timestamp [not null, default: `now()`]
  method        varchar   [not null, default: 'qr', note: 'qr | manual']
  marked_by     varchar   [ref: > user.id, note: 'Diisi jika method = manual (panitia yang absen)']
  device_info   varchar   [note: 'User-agent dari device yang scan QR']

  indexes {
    (campaign_id, submission_id) [unique, name: 'uq_attendance_per_submission', note: 'Satu peserta hanya bisa absen sekali per campaign']
    campaign_id [name: 'idx_attendance_campaign']
  }

  Note: 'Catatan absensi. Dibuat saat peserta scan QR atau panitia absen manual.'
}

Table qr_scan_log {
  id            varchar   [pk, default: `gen_random_uuid()`]
  campaign_id   varchar   [not null, ref: > campaign.id]
  qr_code_token varchar   [not null]
  scanned_at    timestamp [not null, default: `now()`]
  device_info   varchar

  // Hasil verifikasi
  is_valid_registrant boolean  [not null, note: 'true = peserta terdaftar, false = tidak terdaftar']
  submission_id       varchar  [ref: > form_submission.id, note: 'Diisi jika is_valid_registrant = true']

  Note: 'Log SEMUA scan QR, termasuk yang tidak terdaftar. Berguna untuk audit & analitik.'
}


// =============================================================
// SECTION 6: TEMPLATE EMAIL & SERTIFIKAT
// =============================================================

Table email_template {
  id            varchar   [pk, default: `gen_random_uuid()`]
  campaign_id   varchar   [not null, unique, ref: > campaign.id]

  // Konten (dikerjakan copywriter)
  subject                 varchar   [note: 'Subjek email sertifikat. Mendukung variabel {{...}}']
  body_html               text      [note: 'Body email HTML. Mendukung variabel {{nama}}, {{event}}, dst.']
  confirmation_subject    varchar   [note: 'Subjek email konfirmasi pendaftaran']
  confirmation_body_html  text      [note: 'Body email konfirmasi pendaftaran']

  // Desain (dikerjakan desainer) — Header Email
  header_image_url    varchar   [note: 'URL gambar header email']
  header_bg_color     varchar   [default: '#ffffff']
  footer_text         text      [note: 'Teks footer email, bisa berisi nama org, kontak, dsb.']

  // Share link untuk kolaborasi
  copywriter_share_token  varchar   [unique, note: 'Token akses untuk copywriter tanpa login']
  copywriter_token_expires_at timestamp
  designer_share_token    varchar   [unique, note: 'Token akses untuk desainer tanpa login']
  designer_token_expires_at timestamp

  last_edited_by  varchar   [ref: > user.id]
  created_at  timestamp [not null, default: `now()`]
  updated_at  timestamp [not null, default: `now()`]

  Note: 'Template email (konten + desain header) per campaign. Satu campaign, satu template.'
}

Table certificate_template {
  id            varchar   [pk, default: `gen_random_uuid()`]
  campaign_id   varchar   [not null, unique, ref: > campaign.id]

  // Aset
  background_image_url  varchar   [not null, note: 'URL gambar latar sertifikat (PNG/JPG)']
  output_format         varchar   [not null, default: 'pdf', note: 'pdf | png']
  width_px              int       [not null, default: 2480, note: 'Lebar canvas sertifikat dalam pixel (A4 landscape ~2480px)']
  height_px             int       [not null, default: 1754, note: 'Tinggi canvas sertifikat dalam pixel']

  // Share link untuk desainer
  designer_share_token    varchar   [unique, note: 'Token akses untuk desainer, terpisah dari email template']
  designer_token_expires_at timestamp

  last_edited_by  varchar   [ref: > user.id]
  created_at  timestamp [not null, default: `now()`]
  updated_at  timestamp [not null, default: `now()`]

  Note: 'Template sertifikat per campaign. Berisi background dan konfigurasi elemen teks dinamis.'
}

Table certificate_element {
  id                    varchar   [pk, default: `gen_random_uuid()`]
  certificate_template_id varchar [not null, ref: > certificate_template.id]

  // Jenis elemen
  element_type  varchar   [not null, note: 'text | image']
  label         varchar   [not null, note: 'Nama elemen, e.g.: "Nama Peserta", "Logo Organisasi"']

  // Untuk elemen teks
  variable      varchar   [note: 'Variabel dinamis, e.g.: {{nama}}, {{role}}, {{tanggal_event}}. Null jika teks statis.']
  static_text   varchar   [note: 'Teks statis jika bukan variabel, e.g.: "Telah berpartisipasi dalam"']
  font_family   varchar   [default: 'Arial']
  font_size     int       [default: 48]
  font_color    varchar   [default: '#000000']
  font_weight   varchar   [default: 'normal', note: 'normal | bold']
  text_align    varchar   [default: 'center', note: 'left | center | right']

  // Untuk elemen gambar
  image_url     varchar   [note: 'URL gambar statis, e.g.: tanda tangan, logo']

  // Posisi & dimensi (dalam pixel, relatif terhadap canvas)
  pos_x     int       [not null, default: 0]
  pos_y     int       [not null, default: 0]
  width     int
  height    int

  sort_order  int [default: 0]

  Note: 'Setiap elemen teks/gambar yang di-overlay di atas background sertifikat.'
}


// =============================================================
// SECTION 7: PENGIRIMAN SERTIFIKAT (DELIVERY)
// =============================================================

Table delivery_job {
  id            varchar   [pk, default: `gen_random_uuid()`]
  campaign_id   varchar   [not null, ref: > campaign.id]
  triggered_by  varchar   [not null, ref: > user.id]

  // Filter peserta yang menjadi target
  target_filter varchar   [not null, note: 'all_registered | all_attended | manual_select']
  total_target  int       [not null, default: 0]
  total_sent    int       [not null, default: 0]
  total_success int       [not null, default: 0]
  total_failed  int       [not null, default: 0]

  status        varchar   [not null, default: 'pending', note: 'pending | processing | completed | failed | cancelled']
  started_at    timestamp
  completed_at  timestamp

  // Untuk keperluan re-run / debug
  celery_task_id  varchar [note: 'ID task dari Celery / BullMQ untuk monitoring']
  error_summary   text

  created_at  timestamp [not null, default: `now()`]

  indexes {
    campaign_id [name: 'idx_delivery_campaign']
  }

  Note: 'Satu record = satu sesi pengiriman sertifikat yang di-trigger panitia.'
}

Table email_log {
  id              varchar   [pk, default: `gen_random_uuid()`]
  delivery_job_id varchar   [not null, ref: > delivery_job.id]
  submission_id   varchar   [not null, ref: > form_submission.id]
  campaign_id     varchar   [not null, ref: > campaign.id]

  // Identitas penerima (di-cache untuk keperluan log historis)
  recipient_name  varchar
  recipient_email varchar   [not null]

  // Status pengiriman
  status          varchar   [not null, default: 'pending', note: 'pending | processing | sent | failed | bounced']
  sent_at         timestamp
  error_message   text      [note: 'Pesan error dari SMTP/Gmail API jika gagal']
  retry_count     int       [not null, default: 0]

  // Attachment
  certificate_file_url varchar [note: 'URL sertifikat yang di-generate di S3/R2. Kosong jika gagal generate.']

  indexes {
    delivery_job_id [name: 'idx_emaillog_job']
    (delivery_job_id, submission_id) [unique, name: 'uq_email_per_job']
    status [name: 'idx_emaillog_status']
  }

  Note: 'Log pengiriman per peserta per sesi delivery. Dasar dari dashboard monitoring real-time.'
}


// =============================================================
// SECTION 8: SHARE LINK (AKSES KOLABORATOR)
// =============================================================

Table share_link {
  id              varchar   [pk, default: `gen_random_uuid()`]
  organization_id varchar   [not null, ref: > organization.id]
  campaign_id     varchar   [not null, ref: > campaign.id]
  created_by      varchar   [not null, ref: > user.id]

  token           varchar   [not null, unique, note: 'Token acak yang ada di URL']
  resource_type   varchar   [not null, note: 'email_content | certificate_design | email_design']
  permission      varchar   [not null, default: 'edit', note: 'view | edit']
  label           varchar   [note: 'Nama/keterangan link, e.g.: "Link untuk Budi Desainer"']

  is_active       boolean   [not null, default: true]
  expires_at      timestamp [note: 'Null = tidak kedaluwarsa hingga di-revoke manual']
  last_accessed_at timestamp
  access_count    int       [not null, default: 0]

  revoked_at      timestamp
  revoked_by      varchar   [ref: > user.id]

  created_at  timestamp [not null, default: `now()`]

  indexes {
    token [unique, name: 'idx_sharelink_token']
    campaign_id [name: 'idx_sharelink_campaign']
  }

  Note: 'Token akses sementara untuk kolaborator (copywriter, desainer) tanpa perlu login ke sistem.'
}


// =============================================================
// SECTION 9: ACTIVITY LOG (AUDIT TRAIL)
// =============================================================

Table activity_log {
  id              varchar   [pk, default: `gen_random_uuid()`]
  organization_id varchar   [not null, ref: > organization.id]
  actor_user_id   varchar   [ref: > user.id, note: 'Null jika aksi dilakukan oleh kolaborator via share link']
  share_link_id   varchar   [ref: > share_link.id, note: 'Diisi jika aksi dilakukan via share link']
  campaign_id     varchar   [ref: > campaign.id]

  action          varchar   [not null, note: 'e.g.: campaign.created, form.published, delivery.triggered, member.invited']
  resource_type   varchar   [note: 'campaign | form | member | delivery | template']
  resource_id     varchar   [note: 'ID dari resource yang diubah']
  metadata        jsonb     [note: 'Data kontekstual tambahan, e.g.: {old_status: "draft", new_status: "published"}']

  ip_address      varchar
  created_at      timestamp [not null, default: `now()`]

  indexes {
    organization_id [name: 'idx_activitylog_org']
    actor_user_id   [name: 'idx_activitylog_user']
    campaign_id     [name: 'idx_activitylog_campaign']
    created_at      [name: 'idx_activitylog_time']
  }

  Note: 'Audit trail semua aksi penting di dalam satu workspace organisasi.'
}


// =============================================================
// REFERENSI VARIABEL DINAMIS YANG DIDUKUNG
//
// Variabel ini digunakan di email_template.body_html,
// email_template.subject, dan certificate_element.variable.
//
// Sumber data per variabel:
//   {{nama}}          → form_submission.respondent_name
//   {{email}}         → form_submission.respondent_email
//   {{event}}         → campaign.name
//   {{tanggal_event}} → campaign.event_date (formatted)
//   {{lokasi}}        → campaign.location
//   {{organisasi}}    → organization.name
//   {{role}}          → form_submission_value WHERE field_key = 'role'
//   {{[field_key]}}   → form_submission_value WHERE field_key = [field_key]
//                       (variabel kustom dari field apapun di form)
// =============================================================


// =============================================================
// CATATAN IMPLEMENTASI
//
// 1. ISOLASI TENANT (KRITIS):
//    Setiap tabel data bisnis memiliki kolom organization_id.
//    Semua query WAJIB difilter dengan organization_id dari
//    session aktif (di-inject oleh auth middleware).
//    Aktifkan Row-Level Security (RLS) di PostgreSQL.
//
// 2. ENKRIPSI:
//    Kolom sensitif yang harus dienkripsi di aplikasi layer
//    sebelum disimpan ke DB:
//      - organization_email_credential.google_access_token
//      - organization_email_credential.google_refresh_token
//      - organization_email_credential.smtp_password
//
// 3. SOFT DELETE:
//    Pertimbangkan menambahkan kolom `deleted_at` pada tabel
//    campaign, form_submission, dan member untuk keperluan
//    recovery data.
//
// 4. BETTER AUTH CLI:
//    Jalankan `npx @better-auth/cli generate` setelah
//    konfigurasi better-auth untuk men-generate migration
//    tabel Section 1 & 2 secara otomatis.
// =============================================================
